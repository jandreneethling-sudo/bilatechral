<%- include('../partials/header', { title, currentUser }) %>

<section class="hero hero-showcase">
  <div class="hero-copy">
    <p class="eyebrow">Bilatechral Solutions (PTY) Ltd</p>
    <h1>Steelpoort’s Trusted Chrome Exchange and Operations Partner</h1>
    <p>
      Nestled in the heart of Steelpoort, Bilatechral Solutions serves mines and traders as a
      professional exchange point for the chrome industry, combining practical yard operations
      with disciplined transaction control.
    </p>
    <div class="actions-row">
      <a class="btn" href="/company-profile">View Company Profile</a>
      <a class="btn secondary" href="/login">Staff Login</a>
    </div>
  </div>
  <div class="hero-image">
    <img
      src="/images/hero/hero-1-900.jpg"
      srcset="/images/hero/hero-1-900.jpg 900w, /images/hero/hero-1-1600.jpg 1600w"
      sizes="(max-width: 900px) 100vw, 48vw"
      alt="Bilatechral field operations"
      fetchpriority="high"
    />
  </div>
</section>

<section class="hero-metrics">
  <article class="metric-item">
    <h3>Exchange Point Operations</h3>
    <p>Structured receiving, stockpiling and dispatch support for chrome suppliers and buyers.</p>
  </article>
  <article class="metric-item">
    <h3>Weighbridge Discipline</h3>
    <p>Accurate tare, gross and net captures to support transport and settlement decisions.</p>
  </article>
  <article class="metric-item">
    <h3>Offtake Access</h3>
    <p>Multiple end-customer channels that help facilitate chrome ROM and concentrate sales.</p>
  </article>
</section>

<section class="showcase-grid">
  <article class="showcase-tile">
    <img
      src="/images/hero/hero-2-900.jpg"
      srcset="/images/hero/hero-2-900.jpg 900w, /images/hero/hero-2-1600.jpg 1600w"
      sizes="(max-width: 900px) 100vw, 33vw"
      alt="Bilatechral mining operations"
      loading="lazy"
    />
    <div class="tile-overlay">On-site Operations</div>
  </article>
  <article class="showcase-tile">
    <img
      src="/images/hero/hero-3-900.jpg"
      srcset="/images/hero/hero-3-900.jpg 900w, /images/hero/hero-3-1600.jpg 1600w"
      sizes="(max-width: 900px) 100vw, 33vw"
      alt="Bilatechral stockpile and processing"
      loading="lazy"
    />
    <div class="tile-overlay">Stockpile & Processing</div>
  </article>
  <article class="showcase-tile">
    <img
      src="/artwork/ops_weighbridge.jpeg"
      alt="Bilatechral weighbridge station"
      loading="lazy"
    />
    <div class="tile-overlay">Weighbridge Control</div>
  </article>
</section>

<section class="cards three">
  <article class="card">
    <h3>Own Mining + Industry Support</h3>
    <p>
      Apart from our own chrome ore mining activities, we provide operating support to external
      mines and traders requiring dependable handling capacity.
    </p>
  </article>
  <article class="card">
    <h3>Stockpiling for Testing & Distribution</h3>
    <p>
      Customers stockpile product with us for testing and onward distribution, with clear
      movement control across the yard.
    </p>
  </article>
  <article class="card">
    <h3>Trading Flow Enablement</h3>
    <p>
      We help bridge operational and commercial requirements from inbound loads through outbound
      transport, sale facilitation and documentation.
    </p>
  </article>
</section>

<%- include('../partials/footer') %>
