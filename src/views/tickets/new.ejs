<%- include('../partials/header', { title, currentUser: user }) %>

<section class="page-head">
  <h1>Capture New Weighbridge Ticket</h1>
  <p>Staff must enter tare and gross weights to calculate net tonnage.</p>
</section>

<section class="card">
  <% if (error) { %>
  <div class="alert"><%= error %></div>
  <% } %>

  <form method="post" action="/tickets" class="form-grid two-cols">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <label>
      Transaction Type
      <select name="transactionType" required>
        <option value="supplier_offload">Supplier Offload (Pay Supplier)</option>
        <option value="customer_load">Customer Load (Invoice Customer)</option>
      </select>
    </label>

    <label>
      Party Name (Supplier or Customer)
      <input type="text" name="partyName" required />
    </label>

    <label>
      Truck Registration
      <input type="text" name="truckRegistration" required />
    </label>

    <label>
      Driver Name
      <input type="text" name="driverName" />
    </label>

    <label>
      Ore Grade / Product
      <input type="text" name="oreGrade" />
    </label>

    <label>
      Unit Price (R per ton)
      <input type="number" name="unitPrice" min="0" step="0.01" />
    </label>

    <label>
      Tare Weight (tons)
      <input type="number" name="tareWeight" min="0" step="0.001" required />
    </label>

    <label>
      Gross Weight (tons)
      <input type="number" name="grossWeight" min="0" step="0.001" required />
    </label>

    <label class="full">
      Notes
      <textarea name="notes" rows="4"></textarea>
    </label>

    <button class="btn full" type="submit">Save and Generate Receipt</button>
  </form>
</section>

<%- include('../partials/footer') %>
